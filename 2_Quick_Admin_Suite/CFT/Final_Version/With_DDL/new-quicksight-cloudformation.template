        "AdminConsoleDashboardLoad2025": {
            "Type": "AWS::QuickSight::DataSet",
            "DependsOn": [
                "qsdatasource"
            ],
            "Properties": {
                "AwsAccountId": {
                    "Fn::Sub": "${AWS::AccountId}"
                },
                "DataSetId": {
                    "Fn::Sub": "Admin-Console-Dashboard-Load-2025-${AWS::AccountId}"
                },
                "Name": "Admin-Console-Dashboard-Load-2025",
                "Permissions": [
                    {
                        "Principal": {
                            "Ref": "adminarn"
                        },
                        "Actions": [
                            "quicksight:UpdateDataSetPermissions",
                            "quicksight:DescribeDataSet",
                            "quicksight:DescribeDataSetPermissions",
                            "quicksight:PassDataSet",
                            "quicksight:DescribeIngestion",
                            "quicksight:ListIngestions",
                            "quicksight:UpdateDataSet",
                            "quicksight:DeleteDataSet",
                            "quicksight:CreateIngestion",
                            "quicksight:CancelIngestion"
                        ]
                    }
                ],
                "PhysicalTableMap": {
                    "e60bec59-c6d9-46df-b44c-f0871aba2e15": {
                        "CustomSql": {
                            "DataSourceArn": {
                                "Fn::GetAtt": [
                                    "qsdatasource",
                                    "Arn"
                                ]
                            },
                            "Name": "cw_qs_dash_visual_pivot",
                            "SqlQuery": "SELECT\r\n  p.*,\r\n  d.dashboard_name\r\nFROM \"admin-console-2025\".\"cw_qs_dash_visual_pivot\" AS p\r\nLEFT JOIN (\r\n  SELECT\r\n    aws_region,\r\n    dashboardid,\r\n    MIN(dashboard_name) AS dashboard_name  -- pick one name per (region, dashboard)\r\n  FROM \"admin-console-2025\".\"datasets_info\"\r\n  WHERE dashboardid IS NOT NULL AND dashboardid <> ''\r\n  GROUP BY aws_region, dashboardid\r\n) AS d\r\n  ON d.dashboardid = p.dashboardid\r\n AND d.aws_region  = p.region",
                            "Columns": [
                                {
                                    "Name": "timestamp",
                                    "Type": "INTEGER"
                                },
                                {
                                    "Name": "account_id",
                                    "Type": "STRING"
                                },
                                {
                                    "Name": "region",
                                    "Type": "STRING"
                                },
                                {
                                    "Name": "dashboardid",
                                    "Type": "STRING"
                                },
                                {
                                    "Name": "sheetid",
                                    "Type": "STRING"
                                },
                                {
                                    "Name": "visualid",
                                    "Type": "STRING"
                                },
                                {
                                    "Name": "DashboardViewCount",
                                    "Type": "INTEGER"
                                },
                                {
                                    "Name": "DashboardViewCount_Unit",
                                    "Type": "STRING"
                                },
                                {
                                    "Name": "DashboardViewLoadTime",
                                    "Type": "DECIMAL"
                                },
                                {
                                    "Name": "DashboardViewLoadTime_Unit",
                                    "Type": "STRING"
                                },
                                {
                                    "Name": "VisualLoadTime",
                                    "Type": "DECIMAL"
                                },
                                {
                                    "Name": "VisualLoadTime_Unit",
                                    "Type": "STRING"
                                },
                                {
                                    "Name": "VisualLoadErrorCount",
                                    "Type": "INTEGER"
                                },
                                {
                                    "Name": "VisualLoadErrorCount_Unit",
                                    "Type": "STRING"
                                },
                                {
                                    "Name": "dashboard_name",
                                    "Type": "STRING"
                                }
                            ]
                        }
                    }
                },
                "LogicalTableMap": {
                    "def83dc5-0912-45c1-9fe3-ff4602d60cb0": {
                        "Alias": "cw_qs_dash_visual_pivot",
                        "DataTransforms": [
                            {
                                "TagColumnOperation": {
                                    "ColumnName": "region",
                                    "Tags": [
                                        {
                                            "ColumnGeographicRole": "STATE"
                                        }
                                    ]
                                }
                            },
                            {
                                "ProjectOperation": {
                                    "ProjectedColumns": [
                                        "timestamp",
                                        "account_id",
                                        "region",
                                        "dashboardid",
                                        "sheetid",
                                        "visualid",
                                        "DashboardViewCount",
                                        "DashboardViewCount_Unit",
                                        "DashboardViewLoadTime",
                                        "DashboardViewLoadTime_Unit",
                                        "VisualLoadTime",
                                        "VisualLoadTime_Unit",
                                        "VisualLoadErrorCount",
                                        "VisualLoadErrorCount_Unit",
                                        "dashboard_name"
                                    ]
                                }
                            }
                        ],
                        "Source": {
                            "PhysicalTableId": "e60bec59-c6d9-46df-b44c-f0871aba2e15"
                        }
                    }
                },
                "ImportMode": "DIRECT_QUERY",
                "FieldFolders": {},
                "DataSetUsageConfiguration": {
                    "DisableUseAsDirectQuerySource": false,
                    "DisableUseAsImportedSource": false
                },
                "DataSetRefreshProperties": {
                    "FailureConfiguration": {
