{
  "DataSetId": "movie-analytics-dataset",
  "Name": "Movie Analytics Dataset",
  "PhysicalTableMap": {
    "movies": {
      "RelationalTable": {
        "DataSourceArn": "arn:aws:quicksight:us-east-1:905178920046:datasource/test-snowflake-datasource",
        "Catalog": "MOVIES",
        "Schema": "PUBLIC",
        "Name": "MOVIES_CURATED",
        "InputColumns": [
          {
            "Name": "MOVIEID",
            "Type": "INTEGER"
          },
          {
            "Name": "RELEASE",
            "Type": "INTEGER"
          },
          {
            "Name": "TITLE",
            "Type": "STRING"
          }
        ]
      }
    },
    "users": {
      "RelationalTable": {
        "DataSourceArn": "arn:aws:quicksight:us-east-1:905178920046:datasource/test-snowflake-datasource",
        "Catalog": "MOVIES",
        "Schema": "PUBLIC",
        "Name": "USERS_CURATED",
        "InputColumns": [
          {
            "Name": "CITY",
            "Type": "STRING"
          },
          {
            "Name": "COUNTRY",
            "Type": "STRING"
          },
          {
            "Name": "EMAIL",
            "Type": "STRING"
          },
          {
            "Name": "FIRSTNAME",
            "Type": "STRING"
          },
          {
            "Name": "LASTNAME",
            "Type": "STRING"
          },
          {
            "Name": "STATE",
            "Type": "STRING"
          },
          {
            "Name": "USERID",
            "Type": "INTEGER"
          }
        ]
      }
    },
    "ratings": {
      "RelationalTable": {
        "DataSourceArn": "arn:aws:quicksight:us-east-1:905178920046:datasource/test-snowflake-datasource",
        "Catalog": "MOVIES",
        "Schema": "PUBLIC",
        "Name": "RATINGS_CURATED",
        "InputColumns": [
          {
            "Name": "MOVIEID",
            "Type": "INTEGER"
          },
          {
            "Name": "RATING",
            "Type": "DECIMAL",
            "SubType": "FLOAT"
          },
          {
            "Name": "TIMESTAMP",
            "Type": "DATETIME"
          },
          {
            "Name": "USERID",
            "Type": "INTEGER"
          }
        ]
      }
    }
  },
  "LogicalTableMap": {
    "movies": {
      "Alias": "MOVIES_CURATED",
      "Source": {
        "PhysicalTableId": "movies"
      },
      "DataTransforms": [
        {
          "RenameColumnOperation": {
            "ColumnName": "TITLE",
            "NewColumnName": "MOVIE_TITLE"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "RELEASE",
            "NewColumnName": "RELEASE_YEAR"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "MOVIEID",
            "NewColumnName": "MOVIES_MOVIE_ID"
          }
        }
      ]
    },
    "users": {
      "Alias": "USERS_CURATED",
      "Source": {
        "PhysicalTableId": "users"
      },
      "DataTransforms": [
        {
          "RenameColumnOperation": {
            "ColumnName": "FIRSTNAME",
            "NewColumnName": "USER_FIRST_NAME"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "EMAIL",
            "NewColumnName": "USER_EMAIL"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "LASTNAME",
            "NewColumnName": "USER_LAST_NAME"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "CITY",
            "NewColumnName": "USER_CITY"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "STATE",
            "NewColumnName": "USER_STATE"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "COUNTRY",
            "NewColumnName": "USER_COUNTRY"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "USERID",
            "NewColumnName": "USERS_USER_ID"
          }
        }
      ]
    },
    "ratings": {
      "Alias": "RATINGS_CURATED",
      "Source": {
        "PhysicalTableId": "ratings"
      },
      "DataTransforms": [
        {
          "RenameColumnOperation": {
            "ColumnName": "TIMESTAMP",
            "NewColumnName": "RATING_TIMESTAMP"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "USERID",
            "NewColumnName": "RATINGS_USER_ID"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "MOVIEID",
            "NewColumnName": "RATINGS_MOVIE_ID"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "RATING",
            "NewColumnName": "RATING_VALUE"
          }
        }
      ]
    },
    "join-1": {
      "Alias": "join-1",
      "Source": {
        "JoinInstruction": {
          "LeftOperand": "ratings",
          "RightOperand": "movies",
          "Type": "OUTER",
          "OnClause": "{RATINGS_MOVIE_ID} = {MOVIES_MOVIE_ID}"
        }
      }
    },
    "join-2": {
      "Alias": "join-2",
      "Source": {
        "JoinInstruction": {
          "LeftOperand": "join-1",
          "RightOperand": "users",
          "Type": "OUTER",
          "OnClause": "{RATINGS_USER_ID} = {USERS_USER_ID}"
        }
      },
      "DataTransforms": [
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "USER_FULL_NAME",
                "ColumnId": "c5f399e4-aecd-4d2a-9903-e93c4e83243c",
                "Expression": "concat({USER_FIRST_NAME}, ' ', {USER_LAST_NAME})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATING_YEAR",
                "ColumnId": "8ab167a9-6abc-46ab-be36-ac676e8f5324",
                "Expression": "extract('YYYY',{RATING_TIMESTAMP})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATING_MONTH",
                "ColumnId": "dc97c91d-c50c-439a-9fbc-40a7a6d7e2e4",
                "Expression": "extract('MM',{RATING_TIMESTAMP})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATING_DAY",
                "ColumnId": "79381862-c7d9-48a2-9102-c46c875b04bc",
                "Expression": "extract('DD',{RATING_TIMESTAMP})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "MOVIES_DISTINCT_MOVIES",
                "ColumnId": "691528b5-c90a-4ea8-b344-784722ef1a7d",
                "Expression": "distinct_count( {MOVIES_MOVIE_ID})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "USERS_DISTINCT_USERS",
                "ColumnId": "0ad388cb-868e-439b-8ef9-cad57217dbb8",
                "Expression": "distinct_count( {USERS_USER_ID})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_TOTAL_RATINGS",
                "ColumnId": "71b62792-733b-45cc-a540-b1a3b0bd3bdc",
                "Expression": "count({RATING_VALUE})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_AVG_RATING",
                "ColumnId": "ec2b06ee-0aae-4bd7-b1ba-5fb3a49e5e9c",
                "Expression": "avg({RATING_VALUE})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_DISTINCT_USERS",
                "ColumnId": "a7ad14f3-9638-4e76-ab89-9477040e95fd",
                "Expression": "distinct_count( {RATINGS_USER_ID})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_DISTINCT_MOVIES",
                "ColumnId": "507216fc-3678-4fff-b04f-47ca9797fd93",
                "Expression": "distinct_count( {RATINGS_MOVIE_ID})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_POPULARITY_SCORE",
                "ColumnId": "e4b3be76-8dd5-4cfd-a21c-cf5303a55c24",
                "Expression": "{RATINGS_TOTAL_RATINGS} * {RATINGS_AVG_RATING}"
              }
            ]
          }
        },
        {
          "TagColumnOperation": {
            "ColumnName": "MOVIE_TITLE",
            "Tags": [
              {
                "ColumnDescription": {
                  "Text": "Title of the movie"
                }
              }
