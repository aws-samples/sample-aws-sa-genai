{
  "DataSetId": "test-movie-analytics-dataset",
  "Name": "test-movie-analytics-dataset",
  "PhysicalTableMap": {
    "movies": {
      "RelationalTable": {
        "DataSourceArn": "arn:aws:quicksight:us-east-1:905178920046:datasource/test-snowflake-datasource",
        "Catalog": "MOVIES",
        "Schema": "PUBLIC",
        "Name": "MOVIES_CURATED",
        "InputColumns": [
          {
            "Name": "MOVIEID",
            "Type": "INTEGER"
          },
          {
            "Name": "RELEASE",
            "Type": "INTEGER"
          },
          {
            "Name": "TITLE",
            "Type": "STRING"
          }
        ]
      }
    },
    "users": {
      "RelationalTable": {
        "DataSourceArn": "arn:aws:quicksight:us-east-1:905178920046:datasource/test-snowflake-datasource",
        "Catalog": "MOVIES",
        "Schema": "PUBLIC",
        "Name": "USERS_CURATED",
        "InputColumns": [
          {
            "Name": "CITY",
            "Type": "STRING"
          },
          {
            "Name": "COUNTRY",
            "Type": "STRING"
          },
          {
            "Name": "EMAIL",
            "Type": "STRING"
          },
          {
            "Name": "FIRSTNAME",
            "Type": "STRING"
          },
          {
            "Name": "LASTNAME",
            "Type": "STRING"
          },
          {
            "Name": "STATE",
            "Type": "STRING"
          },
          {
            "Name": "USERID",
            "Type": "INTEGER"
          }
        ]
      }
    },
    "ratings": {
      "RelationalTable": {
        "DataSourceArn": "arn:aws:quicksight:us-east-1:905178920046:datasource/test-snowflake-datasource",
        "Catalog": "MOVIES",
        "Schema": "PUBLIC",
        "Name": "RATINGS_CURATED",
        "InputColumns": [
          {
            "Name": "MOVIEID",
            "Type": "INTEGER"
          },
          {
            "Name": "RATING",
            "Type": "DECIMAL",
            "SubType": "FLOAT"
          },
          {
            "Name": "TIMESTAMP",
            "Type": "DATETIME"
          },
          {
            "Name": "USERID",
            "Type": "INTEGER"
          }
        ]
      }
    }
  },
  "LogicalTableMap": {
    "movies": {
      "Alias": "MOVIES_CURATED",
      "Source": {
        "PhysicalTableId": "movies"
      },
      "DataTransforms": [
        {
          "RenameColumnOperation": {
            "ColumnName": "TITLE",
            "NewColumnName": "MOVIE_TITLE"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "RELEASE",
            "NewColumnName": "RELEASE_YEAR"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "MOVIEID",
            "NewColumnName": "MOVIES_MOVIE_ID"
          }
        }
      ]
    },
    "users": {
      "Alias": "USERS_CURATED",
      "Source": {
        "PhysicalTableId": "users"
      },
      "DataTransforms": [
        {
          "RenameColumnOperation": {
            "ColumnName": "FIRSTNAME",
            "NewColumnName": "USER_FIRST_NAME"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "EMAIL",
            "NewColumnName": "USER_EMAIL"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "LASTNAME",
            "NewColumnName": "USER_LAST_NAME"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "CITY",
            "NewColumnName": "USER_CITY"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "STATE",
            "NewColumnName": "USER_STATE"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "COUNTRY",
            "NewColumnName": "USER_COUNTRY"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "USERID",
            "NewColumnName": "USERS_USER_ID"
          }
        }
      ]
    },
    "ratings": {
      "Alias": "RATINGS_CURATED",
      "Source": {
        "PhysicalTableId": "ratings"
      },
      "DataTransforms": [
        {
          "RenameColumnOperation": {
            "ColumnName": "TIMESTAMP",
            "NewColumnName": "RATING_TIMESTAMP"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "USERID",
            "NewColumnName": "RATINGS_USER_ID"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "MOVIEID",
            "NewColumnName": "RATINGS_MOVIE_ID"
          }
        },
        {
          "RenameColumnOperation": {
            "ColumnName": "RATING",
            "NewColumnName": "RATING_VALUE"
          }
        }
      ]
    },
    "join-1": {
      "Alias": "join-1",
      "Source": {
        "JoinInstruction": {
          "LeftOperand": "ratings",
          "RightOperand": "movies",
          "Type": "OUTER",
          "OnClause": "{RATINGS_MOVIE_ID} = {MOVIES_MOVIE_ID}"
        }
      }
    },
    "join-2": {
      "Alias": "join-2",
      "Source": {
        "JoinInstruction": {
          "LeftOperand": "join-1",
          "RightOperand": "users",
          "Type": "OUTER",
          "OnClause": "{RATINGS_USER_ID} = {USERS_USER_ID}"
        }
      },
      "DataTransforms": [
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "USER_FULL_NAME",
                "ColumnId": "cb938e00-f185-43e6-bb56-373d2836a578",
                "Expression": "concat({USER_FIRST_NAME}, ' ', {USER_LAST_NAME})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATING_YEAR",
                "ColumnId": "036ff6e1-a9f7-4b0f-bc97-b704874d3bec",
                "Expression": "extract('YYYY',{RATING_TIMESTAMP})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATING_MONTH",
                "ColumnId": "00e706cc-cf6d-424a-8213-542d7f6a7cf6",
                "Expression": "extract('MM',{RATING_TIMESTAMP})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATING_DAY",
                "ColumnId": "388ab724-5b55-46ff-a05d-e3069688db10",
                "Expression": "extract('DD',{RATING_TIMESTAMP})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "MOVIES_DISTINCT_MOVIES",
                "ColumnId": "672df3a3-c68f-4ddf-9402-28f0e11f15d0",
                "Expression": "distinct_count( {MOVIES_MOVIE_ID})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "USERS_DISTINCT_USERS",
                "ColumnId": "1c368739-c5c4-484c-81d0-bf53ce99eb4a",
                "Expression": "distinct_count( {USERS_USER_ID})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_TOTAL_RATINGS",
                "ColumnId": "548403cf-22d0-4ecf-bd41-8ffc3e6a6d54",
                "Expression": "count({RATING_VALUE})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_AVG_RATING",
                "ColumnId": "392b53f4-6ce1-4d8d-bd61-e0136e4394a0",
                "Expression": "avg({RATING_VALUE})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_DISTINCT_USERS",
                "ColumnId": "5209f6ae-e56f-4778-af0f-8f81b294e9af",
                "Expression": "distinct_count( {RATINGS_USER_ID})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_DISTINCT_MOVIES",
                "ColumnId": "c5e69ba3-274d-4a58-aad2-96eaafe5cc1e",
                "Expression": "distinct_count( {RATINGS_MOVIE_ID})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_POPULARITY_SCORE",
                "ColumnId": "6ecf9901-e830-4559-a034-51b8e6d77c2b",
                "Expression": "{RATINGS_TOTAL_RATINGS} * {RATINGS_AVG_RATING}"
              }
            ]
          }
        },
        {
          "TagColumnOperation": {
