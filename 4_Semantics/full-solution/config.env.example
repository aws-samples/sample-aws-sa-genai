# Snowflake to QuickSight Workflow Configuration
# Copy this file to config.env and fill in your values
# Usage: ./run_complete_workflow.sh --config config.env

# Snowflake Configuration
SNOWFLAKE_ACCOUNT="your-account.us-east-1"
SNOWFLAKE_DATABASE="MOVIES"
SNOWFLAKE_WAREHOUSE="WORKSHOPWH"
SNOWFLAKE_USER="your_username"
SNOWFLAKE_PASSWORD="your_password"

# AWS Configuration
AWS_REGION="us-east-1"
AWS_PROFILE=""  # Leave empty to use default credentials

# AWS Secrets Manager
SECRET_NAME="snowflake-credentials"

# QuickSight Data Source
DATASOURCE_ID="movies-snowflake-datasource"
DATASOURCE_NAME="Movies Snowflake Data Source"

# Snowflake DDL
DDL_CSV_PATH="SF_DDL.csv"

# QuickSight Dataset
DATASET_ID="movie-analytics-dataset"
DATASET_NAME="Movie Analytics Dataset"
SCHEMA_OUTPUT="quicksight_schema_complete.json"

# Dataset Sharing (optional)
QUICKSIGHT_USER=""  # Format: Administrator/username or leave empty to skip sharing
