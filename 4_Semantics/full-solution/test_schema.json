            "NewColumnName": "RATING_VALUE"
          }
        }
      ]
    },
    "join-1": {
      "Alias": "join-1",
      "Source": {
        "JoinInstruction": {
          "LeftOperand": "ratings",
          "RightOperand": "movies",
          "Type": "OUTER",
          "OnClause": "{RATINGS_MOVIE_ID} = {MOVIES_MOVIE_ID}"
        }
      }
    },
    "join-2": {
      "Alias": "join-2",
      "Source": {
        "JoinInstruction": {
          "LeftOperand": "join-1",
          "RightOperand": "users",
          "Type": "OUTER",
          "OnClause": "{RATINGS_USER_ID} = {USERS_USER_ID}"
        }
      },
      "DataTransforms": [
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "USER_FULL_NAME",
                "ColumnId": "fbba4b8d-6f0f-4c1b-89ae-d3ce2fccda2e",
                "Expression": "concat({USER_FIRST_NAME}, ' ', {USER_LAST_NAME})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATING_YEAR",
                "ColumnId": "6d3c5139-3bc4-42cc-82a2-2283b32a1658",
                "Expression": "extract('YYYY',{RATING_TIMESTAMP})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATING_MONTH",
                "ColumnId": "6ee16067-cddd-429b-a83b-2b547305f914",
                "Expression": "extract('MM',{RATING_TIMESTAMP})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATING_DAY",
                "ColumnId": "d255df9e-9fed-412d-bcec-8c86decec22d",
                "Expression": "extract('DD',{RATING_TIMESTAMP})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "MOVIES_DISTINCT_MOVIES",
                "ColumnId": "73704694-6305-4294-8b0b-a96171f78f7a",
                "Expression": "distinct_count( {MOVIES_MOVIE_ID})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "USERS_DISTINCT_USERS",
                "ColumnId": "34f1e425-5983-43bd-a7cc-a8bc3563590e",
                "Expression": "distinct_count( {USERS_USER_ID})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_TOTAL_RATINGS",
                "ColumnId": "c0bb93aa-2c7d-4139-8b6c-888e56d3d2b2",
                "Expression": "count({RATING_VALUE})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_AVG_RATING",
                "ColumnId": "91edafeb-810c-455b-bcea-915b16a3d5b5",
                "Expression": "avg({RATING_VALUE})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_DISTINCT_USERS",
                "ColumnId": "0fef7c11-adc1-4137-aee1-834c6d00739d",
                "Expression": "distinct_count( {RATINGS_USER_ID})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_DISTINCT_MOVIES",
                "ColumnId": "16096f9c-7bfd-4730-9db8-a115669bf5a3",
                "Expression": "distinct_count( {RATINGS_MOVIE_ID})"
              }
            ]
          }
        },
        {
          "CreateColumnsOperation": {
            "Columns": [
              {
                "ColumnName": "RATINGS_POPULARITY_SCORE",
                "ColumnId": "855e7542-98e2-4d8b-a641-411cfbddf386",
                "Expression": "{RATINGS_TOTAL_RATINGS} * {RATINGS_AVG_RATING}"
              }
            ]
          }
        },
