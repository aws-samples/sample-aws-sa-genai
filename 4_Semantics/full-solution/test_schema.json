    "join-1": {
      "Alias": "join-1",
      "Source": {
        "JoinInstruction": {
          "LeftOperand": "ratings",
          "RightOperand": "movies",
          "Type": "OUTER",
          "OnClause": "{RATINGS_MOVIE_ID} = {MOVIES_MOVIE_ID}"
        }
      }
    },
    "join-2": {
      "Alias": "join-2",
      "Source": {
        "JoinInstruction": {
          "LeftOperand": "join-1",
          "RightOperand": "users",
          "Type": "OUTER",
          "OnClause": "{RATINGS_USER_ID} = {USERS_USER_ID}"
        }
      },
      "DataTransforms": [
